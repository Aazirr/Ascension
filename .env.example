# Public site URL used for metadata and canonical links
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Supabase analytics ingestion target
# Use your Supabase project URL, for example:
# https://your-project-ref.supabase.co
SUPABASE_URL=

# Server-side only. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback forwarding target for analytics events.
# Leave blank if this portfolio writes directly to Supabase.
ANALYTICS_FORWARD_URL=

# Optional bearer token for the fallback analytics forward target.
ANALYTICS_FORWARD_TOKEN=
